# ==========================================
# Cloud Expense Tracker - Backend Environment
# ==========================================
# Copy this to .env and fill in the values

# Database (use your Neon PostgreSQL connection string)
DATABASE_URL="postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/cloud_expense_tracker?sslmode=require"

# JWT Authentication
JWT_SECRET="your-super-secret-jwt-key-min-16-chars-long"
JWT_REFRESH_SECRET="your-super-secret-refresh-key-min-16-chars"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# Server
PORT=5000
NODE_ENV=development

# CORS (set to your deployed frontend URL)
CORS_ORIGIN="http://localhost:5173"

# Email (Nodemailer) - Optional
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-password"
EMAIL_FROM="Cloud Expense Tracker <noreply@cloudexpensetracker.com>"

# AWS (Optional - for S3 and SES)
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_REGION="us-east-1"
S3_BUCKET_NAME=""

# Frontend URL (for email links)
FRONTEND_URL="http://localhost:5173"
